# Copy this file to .env and adjust values for your environment.

# Port the Flask server listens on (hosting platforms usually set PORT for you)
PORT=5000

# Debug mode: "true" for local development, "false" in production
FLASK_DEBUG=true

# Comma-separated list of allowed frontend origins for CORS.
# Local dev: *
# Production example: CORS_ORIGINS=https://your-app.netlify.app,https://your-app.vercel.app
CORS_ORIGINS=*
